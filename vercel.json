{
  "cleanUrls": true,
  "rewrites": [{ "source": "/(.*)", "destination": "/public/$1" }],
  "headers": [
    {
      "source": "/results.json",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, no-cache, must-revalidate"
        },
        { "key": "Pragma", "value": "no-cache" },
        { "key": "Expires", "value": "0" }
      ]
    }
  ]
}
